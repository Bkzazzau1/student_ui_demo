    },
    {
      "name": "face_landmarker",
      "type": "landmark_extraction",
      "preferred_precision": "fp16",
      "fallback_precision": "int8",
      "mediapipe_task_path": "assets/models/face_landmarker/face_landmarker.task",
      "onnx_path": "assets/models/optimized_vision_runtime/face_landmarker.fp16.onnx"
    }
  ],
  "runtime_preference": {
    "windows": ["onnxruntime_directml", "tensorrt", "onnxruntime_cpu"],
    "macos": ["onnxruntime_coreml", "coreml", "onnxruntime_cpu"],
    "linux": ["tensorrt", "onnxruntime_cpu"]
